FROM golang:1.25-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -o sshcm .

FROM alpine:3.21

RUN apk add --no-cache openssh-client ca-certificates

COPY --from=builder /app/sshcm /usr/local/bin/sshcm

EXPOSE 8080

CMD ["sshcm", "web", "--port", "8080"]
